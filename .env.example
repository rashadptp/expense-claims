# Copy this file to .env and fill in real values.

# Django
SECRET_KEY=django-insecure-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- AI receipt extraction ---------------------------------------------------
# Which provider to use: "groq", "claude", or "mock"
AI_PROVIDER=groq

# Groq (free tier). Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Claude (swap-in later). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# --- Branding ----------------------------------------------------------------
SITE_NAME=ClaimFlow
SITE_TAGLINE=Automated expense & claims management
# Absolute base URL — used to build links (incl. one-click approval) in emails.
# In production set this to your real domain, e.g. https://claims.yourcompany.com
SITE_URL=http://127.0.0.1:8010

# --- Email / notifications ----------------------------------------------------
# Leave EMAIL_HOST blank to PRINT emails to the console (default; great for demo).
# Fill these in to send REAL email. Gmail example shown:
#   1. Enable 2-Step Verification on the Google account.
#   2. Create an "App password" (Google Account → Security → App passwords).
#   3. Use that 16-char password below (NOT your normal Gmail password).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=youraddress@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=ClaimFlow <no-reply@claimflow.app>
# Set to False to silence all outbound notifications.
NOTIFICATIONS_ENABLED=True

# --- Expense policy (used by the validation + approval rules) -----------------
CURRENCY=AED
# Claims at or below this amount skip manager approval
AUTO_APPROVE_THRESHOLD=50
# Claims at or above this amount additionally require management sign-off
HIGH_VALUE_THRESHOLD=500
# Reject receipts older than this many days
MAX_RECEIPT_AGE_DAYS=30
